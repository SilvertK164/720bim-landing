---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((article) => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const tagColors: Record<string, string> = {
  indigo: "bg-indigo/10 text-indigo",
  green: "bg-green/10 text-green",
  coral: "bg-coral/10 text-coral",
  amber: "bg-amber/10 text-amber",
};
---

<Layout title={`${article.data.title} — 720 BIM`} description={article.data.excerpt}>
  <Header />

  <main class="pb-20">
    <!-- Hero del artículo — full bleed behind header -->
    <div class="relative h-[65vh] min-h-[450px] max-h-[650px] overflow-hidden">
      <img
        src={article.data.image}
        alt={article.data.title}
        class="h-full w-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a]/90 via-[#0a0a0a]/30 to-[#0a0a0a]/20"></div>
      <!-- Title overlay on image -->
      <div class="absolute bottom-0 left-0 right-0 px-6 pb-12">
        <div class="mx-auto max-w-[720px]">
          <div class="flex items-center gap-3 mb-4">
            <span class={`inline-block rounded-full px-3 py-1 text-[11px] font-semibold backdrop-blur-sm ${article.data.tagColor === 'indigo' ? 'bg-indigo/20 text-indigo' : article.data.tagColor === 'green' ? 'bg-green/20 text-green' : article.data.tagColor === 'coral' ? 'bg-coral/20 text-coral' : 'bg-amber/20 text-amber'}`}>
              {article.data.tag}
            </span>
            <span class="text-sm text-white/60">
              {article.data.date.toLocaleDateString("es-PE", { year: "numeric", month: "long", day: "numeric" })}
            </span>
          </div>
          <h1 class="font-serif text-4xl font-semibold leading-[1.1] tracking-[-2px] text-white md:text-5xl">
            {article.data.title}
          </h1>
        </div>
      </div>
    </div>

    <article class="mx-auto max-w-[720px] px-6 pt-10 relative z-10">

      <!-- Extracto -->
      <p class="text-lg leading-relaxed text-text-secondary mb-10 border-l-2 border-indigo pl-5">
        {article.data.excerpt}
      </p>

      <!-- Contenido Markdown -->
      <div class="article-content">
        <Content />
      </div>

      <!-- Paper Links -->
      {article.data.paperLinks && article.data.paperLinks.length > 0 && (
        <div class="mt-12 rounded-2xl bg-elevated p-6">
          <h3 class="text-lg font-semibold text-dark mb-4">Referencias y papers</h3>
          <ul class="flex flex-col gap-3">
            {article.data.paperLinks.map((paper) => (
              <li>
                <a
                  href={paper.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center gap-3 rounded-xl bg-white p-4 transition-all duration-300 hover:shadow-md"
                >
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo/10 text-indigo">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                    </svg>
                  </div>
                  <span class="text-sm font-medium text-dark group-hover:text-indigo transition-colors">
                    {paper.title}
                  </span>
                  <svg class="ml-auto h-4 w-4 text-text-secondary transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Navegación -->
      <div class="mt-12 flex items-center justify-between border-t border-border-subtle pt-8">
        <a href="/#articulos" class="flex items-center gap-2 text-sm font-medium text-text-secondary hover:text-dark transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Volver a artículos
        </a>
      </div>
    </article>
  </main>

  <Footer />
</Layout>

<style is:global>
  .article-content h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -1px;
    color: var(--color-dark);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .article-content h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-dark);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .article-content h4 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-dark);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .article-content p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
  }
  .article-content ul, .article-content ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .article-content li {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
  }
  .article-content ul li { list-style-type: disc; }
  .article-content ol li { list-style-type: decimal; }
  .article-content strong {
    color: var(--color-dark);
    font-weight: 600;
  }
  .article-content a {
    color: var(--color-indigo);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .article-content a:hover {
    opacity: 0.8;
  }
</style>
