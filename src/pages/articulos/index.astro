---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const articles = (await getCollection("articles"))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tagColors: Record<string, string> = {
  indigo: "text-indigo",
  green: "text-green",
  coral: "text-coral",
  amber: "text-amber",
};
---

<Layout title="Artículos — 720 BIM" description="Artículos y conocimiento sobre BIM, drones y tecnología para la construcción.">
  <Header />

  <main class="pt-32 pb-20">
    <div class="mx-auto max-w-[1100px] px-6">
      <!-- Header -->
      <div class="mb-16">
        <span class="text-xs font-semibold tracking-[3px] text-indigo">INSIGHTS</span>
        <h1 class="mt-3 font-serif text-4xl font-semibold leading-[1.05] tracking-[-2px] text-dark md:text-5xl">
          Artículos y<br />conocimiento BIM
        </h1>
        <p class="mt-4 max-w-[500px] text-base leading-relaxed text-text-secondary">
          Exploramos las últimas tendencias en tecnología BIM, drones, realidad virtual y normativa para el sector construcción.
        </p>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {articles.map((article) => (
          <a href={`/articulos/${article.id}`} class="group" data-reveal>
            <div class="overflow-hidden rounded-2xl bg-elevated">
              <div class="h-[200px] overflow-hidden">
                <img
                  src={article.data.image}
                  alt={article.data.title}
                  class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <span class={`text-[11px] font-semibold ${tagColors[article.data.tagColor]}`}>
                    {article.data.tag}
                  </span>
                  <span class="text-xs text-text-secondary">
                    {article.data.date.toLocaleDateString("es-PE", { year: "numeric", month: "short" })}
                  </span>
                </div>
                <h2 class="text-lg font-semibold leading-tight tracking-[-0.5px] text-dark group-hover:text-indigo transition-colors">
                  {article.data.title}
                </h2>
                <p class="mt-2 text-sm leading-relaxed text-text-secondary line-clamp-2">
                  {article.data.excerpt}
                </p>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Back -->
      <div class="mt-16 text-center">
        <a href="/" class="inline-flex items-center gap-2 text-sm font-medium text-text-secondary hover:text-dark transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          Volver al inicio
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
