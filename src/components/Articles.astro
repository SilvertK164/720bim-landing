---
import { getCollection } from "astro:content";

const articles = (await getCollection("articles"))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const tagColors: Record<string, string> = {
  indigo: "text-indigo",
  green: "text-green",
  coral: "text-coral",
  amber: "text-amber",
};
---

<section id="articulos" class="bg-base px-6 py-20 md:px-20">
  <div class="mx-auto max-w-[1280px]">
    <!-- Header -->
    <div class="mb-10 flex items-end justify-between">
      <div class="flex flex-col gap-3">
        <span class="text-xs font-semibold tracking-[3px] text-coral">INSIGHTS</span>
        <h2 class="font-serif text-3xl font-semibold leading-[1.1] tracking-[-1.5px] text-dark md:text-[40px]">
          Artículos y<br />conocimiento BIM
        </h2>
      </div>
      <a href="/articulos" class="hidden items-center gap-2 rounded-full border border-border-strong bg-white px-5 py-2.5 text-[13px] font-medium text-text-secondary transition-colors hover:text-dark md:flex">
        Ver todos
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>

    <!-- Articles Grid -->
    <div class="grid gap-5 md:grid-cols-3">
      {articles.map((article, i) => (
        <a href={`/articulos/${article.id}`} class="group cursor-pointer overflow-hidden rounded-2xl border border-border-subtle bg-white transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_60px_rgba(0,0,0,0.06)]" data-reveal data-delay={String(i + 1)}>
          <div class="h-[180px] overflow-hidden bg-elevated">
            <img src={article.data.image} alt={article.data.title} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          </div>
          <div class="flex flex-col gap-2 p-5">
            <span class={`text-[11px] font-semibold ${tagColors[article.data.tagColor]}`}>{article.data.tag}</span>
            <h3 class="text-lg font-bold leading-[1.25] text-dark">{article.data.title}</h3>
            <span class="text-xs text-text-tertiary">
              {article.data.date.toLocaleDateString("es-PE", { year: "numeric", month: "short" })} · 5 min
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
