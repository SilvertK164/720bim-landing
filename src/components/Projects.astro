---
import { getCollection } from "astro:content";

const allProjects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order);

const projects = allProjects;
const videosProjects = allProjects.filter((p) => p.data.videoId);

const statusConfig: Record<string, { label: string; bg: string; text: string; dot: string }> = {
  activo: { label: "Activo", bg: "bg-green/10", text: "text-green", dot: "bg-green" },
  completado: { label: "Completado", bg: "bg-indigo/10", text: "text-indigo", dot: "bg-indigo" },
  "en-ejecucion": { label: "En ejecución", bg: "bg-amber/10", text: "text-amber", dot: "bg-amber" },
};
---

<section id="proyectos" class="bg-white px-6 py-20 md:px-20 overflow-hidden">
  <div class="mx-auto max-w-[1280px]">
    <div class="mb-10 flex items-end justify-between">
      <div class="flex flex-col gap-3">
        <span class="text-xs font-semibold tracking-[3px] text-indigo">PROYECTOS</span>
        <h2 class="font-serif text-3xl font-semibold leading-[1.1] tracking-[-1.5px] text-dark md:text-[42px]">
          Resultados que<br />hablan por sí mismos
        </h2>
      </div>
    </div>

    <!-- Infinite Marquee Carousel -->
    <div class="marquee-container" data-reveal>
      <div class="marquee-track">
        {/* Original set */}
        {projects.map((proj) => {
          const status = statusConfig[proj.data.status];
          return (
            <article class="marquee-card group relative h-[340px] w-[340px] flex-shrink-0 overflow-hidden rounded-[20px] bg-surface md:h-[420px] md:w-[380px]">
              <img src={proj.data.image} alt={proj.data.title} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent transition-all duration-500 group-hover:from-black/90"></div>

              <div class={`absolute top-4 right-4 flex items-center gap-1.5 rounded-full px-3 py-1.5 backdrop-blur-md ${status.bg}`}>
                <span class={`h-1.5 w-1.5 rounded-full ${status.dot}`}></span>
                <span class={`text-[10px] font-semibold ${status.text}`}>{status.label}</span>
              </div>

              <div class="absolute top-4 left-4 rounded-full bg-white/10 px-3 py-1.5 backdrop-blur-md">
                <span class="text-[10px] font-semibold text-white/80">{proj.data.year}</span>
              </div>

              <div class="absolute bottom-0 left-0 right-0 flex flex-col gap-1.5 p-7 transition-transform duration-500 group-hover:-translate-y-1">
                <h3 class="font-serif text-xl font-semibold text-white md:text-[24px]">{proj.data.title}</h3>
                <p class="text-[13px] font-medium text-white/60">{proj.data.services}</p>
                <p class="text-[11px] text-white/40">{proj.data.client}</p>
              </div>
            </article>
          );
        })}
        {/* Duplicate set for seamless loop */}
        {projects.map((proj) => {
          const status = statusConfig[proj.data.status];
          return (
            <article class="marquee-card group relative h-[340px] w-[340px] flex-shrink-0 overflow-hidden rounded-[20px] bg-surface md:h-[420px] md:w-[380px]" aria-hidden="true">
              <img src={proj.data.image} alt="" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent transition-all duration-500 group-hover:from-black/90"></div>

              <div class={`absolute top-4 right-4 flex items-center gap-1.5 rounded-full px-3 py-1.5 backdrop-blur-md ${status.bg}`}>
                <span class={`h-1.5 w-1.5 rounded-full ${status.dot}`}></span>
                <span class={`text-[10px] font-semibold ${status.text}`}>{status.label}</span>
              </div>

              <div class="absolute top-4 left-4 rounded-full bg-white/10 px-3 py-1.5 backdrop-blur-md">
                <span class="text-[10px] font-semibold text-white/80">{proj.data.year}</span>
              </div>

              <div class="absolute bottom-0 left-0 right-0 flex flex-col gap-1.5 p-7 transition-transform duration-500 group-hover:-translate-y-1">
                <h3 class="font-serif text-xl font-semibold text-white md:text-[24px]">{proj.data.title}</h3>
                <p class="text-[13px] font-medium text-white/60">{proj.data.services}</p>
                <p class="text-[11px] text-white/40">{proj.data.client}</p>
              </div>
            </article>
          );
        })}
      </div>
    </div>

    <!-- YouTube Time Lapse Videos -->
    {videosProjects.length > 0 && (
      <div class="mt-16">
        <h3 class="mb-6 text-center font-serif text-2xl font-semibold tracking-[-1px] text-dark md:text-3xl">
          Seguimiento aéreo de obra
        </h3>
        <div class="grid gap-5 md:grid-cols-2">
          {videosProjects.map((proj, i) => {
            const s = statusConfig[proj.data.status];
            return (
              <div class="video-card group overflow-hidden rounded-2xl bg-dark" data-reveal data-delay={String(i)}>
                <div class="relative aspect-video w-full overflow-hidden">
                  <iframe
                    src={`https://www.youtube.com/embed/${proj.data.videoId}?rel=0&modestbranding=1`}
                    title={`${proj.data.title} - Time Lapse`}
                    class="h-full w-full"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                </div>
                <div class="p-5">
                  <div class="flex items-center gap-2">
                    <span class="inline-block rounded-full bg-indigo/20 px-3 py-1 text-[11px] font-semibold text-indigo">Time Lapse</span>
                    <span class={`inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-[10px] font-semibold ${s.bg} ${s.text}`}>
                      <span class={`h-1 w-1 rounded-full ${s.dot}`}></span>
                      {s.label}
                    </span>
                  </div>
                  <h4 class="mt-2 text-lg font-bold text-white">{proj.data.title}</h4>
                  <p class="mt-1 text-[13px] text-white/50">{proj.data.services}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .marquee-container {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }
  .marquee-track {
    display: flex;
    gap: 20px;
    animation: marquee-scroll 25s linear infinite;
    width: max-content;
  }
  .marquee-container:hover .marquee-track {
    animation-play-state: paused;
  }
  .marquee-card {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.5s ease;
  }
  .marquee-card:hover {
    transform: translateY(-8px) !important;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.2);
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(calc(-50% - 10px)); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
  @media (max-width: 768px) {
    .marquee-track {
      animation-duration: 18s;
    }
  }
</style>
