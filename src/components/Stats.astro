---
const stats = [
  { value: 120, suffix: "+", label: "Proyectos completados", color: "bg-indigo" },
  { value: 50, suffix: "+", label: "Clientes satisfechos", color: "bg-green" },
  { value: 15, suffix: "+", label: "Años de experiencia", color: "bg-coral" },
];
---

<section class="bg-base px-6 py-16 md:px-20">
  <div class="mx-auto flex max-w-[1280px] flex-wrap items-center justify-around gap-8">
    {stats.map((stat) => (
      <div class="flex flex-col items-center gap-1" data-reveal>
        <span class="text-5xl font-bold tracking-[-2px] text-dark md:text-[56px]" data-count={stat.value} data-suffix={stat.suffix}>
          0{stat.suffix}
        </span>
        <span class="text-[13px] font-medium text-text-secondary">{stat.label}</span>
        <div class={`mt-1 h-[3px] w-8 rounded-full ${stat.color}`}></div>
      </div>
    ))}
  </div>
</section>

<script>
  import { gsap, ScrollTrigger } from "../scripts/gsap-init";

  document.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => {
    const target = parseInt(el.dataset.count || "0");
    const suffix = el.dataset.suffix || "";
    const proxy = { value: 0 };

    gsap.to(proxy, {
      value: target,
      duration: 2,
      ease: "power2.out",
      scrollTrigger: { trigger: el, start: "top 85%" },
      onUpdate: () => { el.textContent = Math.round(proxy.value) + suffix; },
    });
  });
</script>
