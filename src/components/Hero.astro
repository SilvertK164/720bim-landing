---
// Ubicación contextual: drone arriba (vuela), casco centro-derecha (obra),
// tablet centro-izquierda (planos), VR/AR lados (inmersivo), laptop abajo, 360 lateral
const floatingObjects = [
  { name: "Drone", img: "/images/drone-Photoroom.png", x: "3%", y: "3%", w: 420, h: 300, rotate: -5, delay: 0, dispX: -200, dispY: -140 },
  { name: "VR Headset", img: "/images/gafas-Photoroom.png", x: "74%", y: "1%", w: 380, h: 280, rotate: 8, delay: 0.15, dispX: 180, dispY: -120 },
  { name: "Helmet", img: "/images/casco-Photoroom.png", x: "78%", y: "36%", w: 230, h: 230, rotate: 6, delay: 0.3, dispX: 220, dispY: 70 },
  { name: "Tablet BIM", img: "/images/ipad-Photoroom.png", x: "-1%", y: "45%", w: 340, h: 240, rotate: 5, delay: 0.4, dispX: -220, dispY: 50 },
  { name: "360 Camera", img: "/images/insta360-Photoroom.png", x: "83%", y: "60%", w: 260, h: 260, rotate: -8, delay: 0.5, dispX: 200, dispY: 160 },
  { name: "Laptop", img: "/images/laptop-Photoroom.png", x: "1%", y: "70%", w: 320, h: 220, rotate: -6, delay: 0.6, dispX: -180, dispY: 140 },
  { name: "AR Glasses", img: "/images/lentes-ar-Photoroom.png", x: "78%", y: "76%", w: 260, h: 170, rotate: 4, delay: 0.7, dispX: 170, dispY: 120 },
];
---

<section id="hero" class="relative flex min-h-screen items-center justify-center overflow-hidden">
  <!-- Background Image with parallax -->
  <div class="hero-bg absolute inset-0 z-0">
    <img
      src="/images/hero-bg-dark.jpg"
      alt=""
      class="h-full w-full object-cover scale-110"
      loading="eager"
    />
    <!-- Gradient overlays for depth -->
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0a0a]/40 via-transparent to-[#0a0a0a]/90"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#0a0a0a]/50 via-transparent to-[#0a0a0a]/50"></div>
    <!-- Subtle radial glow center -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 40%, rgba(99,102,241,0.06) 0%, transparent 60%);"></div>
  </div>

  <!-- Floating Tech Objects -->
  {floatingObjects.map((obj, i) => (
    <div
      class="floating-object absolute hidden md:block"
      data-disp-x={obj.dispX}
      data-disp-y={obj.dispY}
      style={`left:${obj.x}; top:${obj.y}; width:${obj.w}px; height:${obj.h}px; transform:rotate(${obj.rotate}deg); animation: floatIn 1s cubic-bezier(0.16,1,0.3,1) ${0.8 + obj.delay}s both, float ${3 + i * 0.7}s ease-in-out ${2 + obj.delay}s infinite alternate;`}
    >
      <img src={obj.img} alt={obj.name} class="h-full w-full object-contain drop-shadow-[0_10px_30px_rgba(255,255,255,0.15)]" loading="eager" />
    </div>
  ))}

  <!-- Hero Content -->
  <div class="relative z-10 flex flex-col items-center gap-7 px-5 text-center">
    <div class="flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-5 py-2 backdrop-blur-sm" style="animation: fadeInUp 0.8s ease-out 0.2s both;">
      <span class="h-1.5 w-1.5 rounded-full bg-indigo"></span>
      <span class="text-xs font-medium text-white/70">Innovación BIM · Desde 2009</span>
    </div>

    <h1 class="hero-title max-w-[800px] font-serif text-5xl font-semibold leading-[1.02] tracking-[-3px] text-white md:text-7xl lg:text-[76px]">
      Donde la tecnología transforma cada proyecto.
    </h1>

    <!-- Typewriter keywords -->
    <div class="flex items-center gap-3 text-lg md:text-xl" style="animation: fadeInUp 0.8s ease-out 0.5s both;">
      <span class="text-white/40">Especialistas en</span>
      <span id="typewriter-text" class="font-semibold text-indigo"></span>
    </div>

    <p class="max-w-[560px] text-base leading-relaxed text-white/60 md:text-lg" style="animation: fadeInUp 0.8s ease-out 0.6s both;">
      Drones, realidad virtual, cámaras 360 y BIM integrado<br class="hidden md:block" />
      para construir con precisión absoluta.
    </p>

    <div class="flex flex-col items-center gap-3.5 sm:flex-row" style="animation: fadeInUp 0.8s ease-out 0.8s both;">
      <a href="#tech" class="btn-magnetic icon-spin flex items-center gap-2.5 rounded-full bg-white px-8 py-4 text-[15px] font-semibold text-dark">
        Explorar servicios
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
      </a>
      <a href="#proyectos" class="btn-magnetic flex items-center gap-2.5 rounded-full border border-white/20 bg-white/5 px-8 py-4 text-[15px] font-medium text-white backdrop-blur-sm">
        Ver proyectos
      </a>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2" style="animation: fadeInUp 0.6s ease-out 1.5s both;">
    <span class="text-[10px] font-medium tracking-[3px] text-white/40">SCROLL</span>
    <div class="h-6 w-px bg-gradient-to-b from-white/40 to-transparent"></div>
  </div>
</section>

<style>
  .hero-title .char {
    display: inline-block;
    perspective: 600px;
    will-change: transform, opacity;
  }
  .hero-title .word {
    display: inline-block;
    overflow: hidden;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes floatIn {
    from { opacity: 0; transform: translateY(30px) scale(0.9); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes float {
    from { transform: translateY(0); }
    to { transform: translateY(-12px); }
  }
</style>

<script>
  import { gsap, ScrollTrigger } from "../scripts/gsap-init";
  import SplitType from "split-type";

  // SplitType text reveal — letters animate in with 3D rotation
  const title = document.querySelector(".hero-title");
  if (title) {
    const split = new SplitType(title as HTMLElement, { types: "chars,words" });
    gsap.set(split.chars, { opacity: 0, y: 60, rotateX: -80 });
    gsap.to(split.chars, {
      opacity: 1,
      y: 0,
      rotateX: 0,
      stagger: 0.025,
      duration: 0.7,
      delay: 0.5,
      ease: "back.out(1.4)",
    });
  }

  // Parallax background image — moves slower than scroll
  gsap.to(".hero-bg img", {
    y: 120,
    scale: 1.15,
    ease: "none",
    scrollTrigger: {
      trigger: "#hero",
      start: "top top",
      end: "bottom top",
      scrub: 1,
    },
  });

  // Parallax dispersión — objetos se alejan del centro hacia los bordes
  document.querySelectorAll<HTMLElement>(".floating-object").forEach((el) => {
    const dispX = parseFloat(el.dataset.dispX || "0");
    const dispY = parseFloat(el.dataset.dispY || "0");
    gsap.to(el, {
      x: dispX,
      y: dispY,
      opacity: 0,
      scale: 0.7,
      rotate: `+=${dispX > 0 ? 15 : -15}`,
      ease: "none",
      scrollTrigger: {
        trigger: "#hero",
        start: "top top",
        end: "80% top",
        scrub: 1.2,
      },
    });
  });

  // Hero content scale out on scroll
  gsap.to("#hero .relative.z-10", {
    scale: 0.95,
    opacity: 0,
    y: -40,
    ease: "none",
    scrollTrigger: {
      trigger: "#hero",
      start: "60% top",
      end: "bottom top",
      scrub: 1,
    },
  });
</script>
