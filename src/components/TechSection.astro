---
---

<section id="tech" class="relative overflow-hidden bg-white px-6 py-24 md:px-20">
  <div class="mx-auto max-w-[1280px]">
    <!-- Header -->
    <div class="mb-16 flex flex-col gap-10 md:flex-row md:items-end md:justify-between">
      <div class="flex flex-col gap-3">
        <span class="text-xs font-semibold tracking-[3px] text-indigo">TECNOLOGÍA</span>
        <h2 class="font-serif text-4xl font-semibold leading-[1.05] tracking-[-2px] text-dark md:text-5xl">
          Herramientas de<br />vanguardia
        </h2>
      </div>
      <p class="max-w-[350px] text-base leading-relaxed text-text-secondary md:text-right">
        Cada proyecto integra las tecnologías más avanzadas del sector construcción.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid auto-rows-[300px] grid-cols-1 gap-5 md:grid-cols-12 md:auto-rows-[340px]">

      <!-- Drone Tracker 3D — HERO CARD (spans 8 cols) -->
      <div class="bento-card group relative col-span-1 overflow-hidden rounded-3xl md:col-span-8" data-reveal>
        <!-- Real photo background -->
        <img src="/images/720bim-original/02-equipo-drone-terreno.jpg" alt="" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-r from-dark/90 via-dark/70 to-dark/30"></div>
        <div class="relative z-10 flex h-full flex-col justify-between p-8 md:p-10">
          <div>
            <span class="inline-block rounded-full bg-indigo/20 px-3 py-1 text-[11px] font-semibold text-indigo backdrop-blur-sm">Plataforma propia</span>
            <h3 class="mt-3 text-2xl font-bold leading-[1.15] tracking-[-1px] text-white md:text-[32px]">
              Drone Tracker 3D
            </h3>
          </div>
          <p class="max-w-[400px] text-[13px] leading-relaxed text-white/60">
            Plataforma propia de gestión de vuelos con mapa 3D interactivo,
            fotos geolocalizadas por GPS, filtros temporales y exportación de datos.
            +9,000 fotos procesadas en proyectos activos.
          </p>
        </div>
        <!-- 3D Drone floating inside card -->
        <div class="card-object absolute right-6 top-1/2 -translate-y-1/2 w-[40%] transition-all duration-700 ease-out group-hover:scale-110 group-hover:-translate-y-[55%] group-hover:rotate-[-5deg] md:right-10">
          <img src="/images/drone-Photoroom.png" alt="Drone" class="w-full object-contain drop-shadow-[0_20px_40px_rgba(255,255,255,0.2)]" />
        </div>
      </div>

      <!-- Realidad Virtual (4 cols) -->
      <div class="bento-card group col-span-1 overflow-hidden rounded-3xl bg-elevated p-7 md:col-span-4" data-reveal data-delay="1">
        <span class="inline-block rounded-full bg-green/10 px-3 py-1 text-[11px] font-semibold text-green">Inmersivo</span>
        <h3 class="mt-3 text-[22px] font-bold tracking-[-0.5px] text-dark">Realidad Virtual</h3>
        <p class="mt-2 text-[13px] leading-relaxed text-text-secondary">Recorridos virtuales del proyecto antes de construir.</p>
        <!-- VR Headset inside card -->
        <div class="card-object mt-4 flex items-center justify-center h-[160px] transition-all duration-700 ease-out group-hover:scale-110 group-hover:-translate-y-2">
          <img src="/images/gafas-Photoroom.png" alt="VR Headset" class="h-full object-contain drop-shadow-[0_15px_30px_rgba(50,213,131,0.25)]" />
        </div>
      </div>

      <!-- Cámaras 360 (4 cols) -->
      <div class="bento-card group relative col-span-1 overflow-hidden rounded-3xl md:col-span-4" data-reveal>
        <img src="/images/720bim-original/03-scanner-3d-obra.jpg" alt="" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-dark/80 via-dark/40 to-dark/20"></div>
        <div class="relative z-10 flex h-full flex-col justify-between p-7">
          <div>
            <span class="inline-block rounded-full bg-coral/20 px-3 py-1 text-[11px] font-semibold text-coral backdrop-blur-sm">360°</span>
            <h3 class="mt-3 text-[22px] font-bold tracking-[-0.5px] text-white">Cámaras 360</h3>
          </div>
          <p class="text-[13px] leading-relaxed text-white/60">Documentación inmersiva de cada etapa del proyecto.</p>
        </div>
        <!-- Floating 360 camera -->
        <div class="card-object absolute right-4 top-4 w-[80px] transition-all duration-700 ease-out group-hover:scale-110 group-hover:-translate-y-2 group-hover:rotate-[8deg]">
          <img src="/images/insta360-Photoroom.png" alt="" class="w-full object-contain drop-shadow-[0_10px_20px_rgba(255,255,255,0.2)]" />
        </div>
      </div>

      <!-- Modelado BIM — DARK (4 cols) -->
      <div class="bento-card group col-span-1 overflow-hidden rounded-3xl bg-dark p-8 md:col-span-4" data-reveal data-delay="1">
        <span class="inline-block rounded-full bg-white/10 px-3 py-1 text-[11px] font-semibold text-white">Core</span>
        <h3 class="mt-3 text-[26px] font-bold leading-[1.15] tracking-[-1px] text-white">
          Modelado BIM<br />integrado
        </h3>
        <p class="mt-3 text-[13px] leading-relaxed text-white/50">Coordinación multidisciplinaria, detección de interferencias y generación de RDIs.</p>
        <!-- Laptop inside card -->
        <div class="card-object mt-4 flex items-center justify-center h-[120px] transition-all duration-700 ease-out group-hover:scale-110 group-hover:-translate-y-2">
          <img src="/images/laptop-Photoroom.png" alt="Laptop BIM" class="h-full object-contain drop-shadow-[0_15px_30px_rgba(99,102,241,0.3)]" />
        </div>
      </div>

      <!-- Realidad Aumentada (4 cols) -->
      <div class="bento-card group col-span-1 overflow-hidden rounded-3xl bg-elevated p-7 md:col-span-4" data-reveal data-delay="2">
        <span class="inline-block rounded-full bg-amber/10 px-3 py-1 text-[11px] font-semibold text-amber">AR</span>
        <h3 class="mt-3 text-[22px] font-bold leading-[1.15] tracking-[-0.5px] text-dark">
          Realidad<br />Aumentada
        </h3>
        <p class="mt-2 text-[13px] leading-relaxed text-text-secondary">Superponer modelos BIM en el sitio real de obra.</p>
        <!-- AR Glasses inside card -->
        <div class="card-object mt-3 flex items-center justify-center h-[120px] transition-all duration-700 ease-out group-hover:scale-115 group-hover:-translate-y-2 group-hover:rotate-[-3deg]">
          <img src="/images/lentes-ar-Photoroom.png" alt="AR Glasses" class="h-full object-contain drop-shadow-[0_15px_30px_rgba(255,181,71,0.25)]" />
        </div>
      </div>

      <!-- Dashboards — with real photo (8 cols) -->
      <div class="bento-card group relative col-span-1 overflow-hidden rounded-3xl md:col-span-8" data-reveal>
        <img src="/images/720bim-original/01-escritorio-bim.jpg" alt="" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-r from-dark/85 via-dark/60 to-dark/20"></div>
        <div class="relative z-10 flex h-full flex-col justify-between p-8 md:p-10">
          <div>
            <span class="inline-block rounded-full bg-indigo/20 px-3 py-1 text-[11px] font-semibold text-indigo backdrop-blur-sm">Seguimiento</span>
            <h3 class="mt-3 text-2xl font-bold leading-[1.15] tracking-[-1px] text-white md:text-[28px]">
              Dashboards interactivos<br />para control de obra
            </h3>
          </div>
          <p class="max-w-[380px] text-[13px] leading-relaxed text-white/60">
            Control integrado BIM + avance real. RDIs, interferencias,
            cubicaciones y modelo 3D navegable en vivo.
          </p>
        </div>
        <!-- iPad/Tablet floating -->
        <div class="card-object absolute right-6 top-1/2 -translate-y-1/2 w-[35%] transition-all duration-700 ease-out group-hover:scale-110 group-hover:-translate-y-[55%] group-hover:rotate-[3deg] md:right-10">
          <img src="/images/ipad-Photoroom.png" alt="Dashboard BIM" class="w-full object-contain drop-shadow-[0_20px_40px_rgba(255,255,255,0.2)]" />
        </div>
      </div>

      <!-- Métricas en vivo (4 cols) -->
      <div class="bento-card group col-span-1 flex flex-col justify-center gap-5 overflow-hidden rounded-3xl bg-elevated p-8 md:col-span-4" data-reveal data-delay="1">
        <h3 class="text-[28px] font-bold leading-[1.15] tracking-[-1px] text-dark">Métricas<br />en vivo</h3>
        <p class="text-[13px] leading-relaxed text-text-secondary">Avance de obra, presupuesto ejecutado, RDIs pendientes.</p>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <div class="h-2 flex-1 rounded-full bg-border-strong"><div class="h-2 w-[78%] rounded-full bg-indigo transition-all duration-1000 group-hover:w-[85%]"></div></div>
            <span class="text-sm font-bold text-dark">78%</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="h-2 flex-1 rounded-full bg-border-strong"><div class="h-2 w-[62%] rounded-full bg-green transition-all duration-1000 group-hover:w-[70%]"></div></div>
            <span class="text-sm font-bold text-dark">62%</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="h-2 flex-1 rounded-full bg-border-strong"><div class="h-2 w-[91%] rounded-full bg-coral transition-all duration-1000 group-hover:w-[95%]"></div></div>
            <span class="text-sm font-bold text-dark">91%</span>
          </div>
        </div>
        <!-- Casco floating subtle -->
        <div class="card-object absolute -bottom-4 -right-4 w-[100px] opacity-20 transition-all duration-700 group-hover:opacity-40 group-hover:-translate-y-2">
          <img src="/images/casco-Photoroom.png" alt="" class="w-full object-contain" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .bento-card {
    position: relative;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.6s ease;
    transform-style: preserve-3d;
  }
  .bento-card:hover {
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.1);
  }
  /* Floating animation for card objects */
  .card-object img {
    animation: cardFloat 4s ease-in-out infinite alternate;
  }
  @keyframes cardFloat {
    from { transform: translateY(0); }
    to { transform: translateY(-8px); }
  }
</style>

<script>
  import { gsap, ScrollTrigger } from "../scripts/gsap-init";

  // 3D tilt effect on hover for bento cards
  document.querySelectorAll<HTMLElement>('.bento-card').forEach((card) => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const rotateX = ((y - rect.height / 2) / (rect.height / 2)) * -5;
      const rotateY = ((x - rect.width / 2) / (rect.width / 2)) * 5;
      card.style.transform = `perspective(800px) translateY(-6px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transform = '';
    });
  });

  // Scroll reveal for cards — use set + timeline to avoid invisible cards
  gsap.utils.toArray<HTMLElement>('.bento-card').forEach((card, i) => {
    gsap.set(card, { opacity: 1 }); // ensure visible by default
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: card,
        start: "top 90%",
        toggleActions: "play none none none",
      },
    });
    tl.fromTo(card,
      { y: 40, opacity: 0, scale: 0.97 },
      { y: 0, opacity: 1, scale: 1, duration: 0.7, delay: i * 0.08, ease: "power2.out" }
    );
  });

  // Parallax for 3D objects inside cards on scroll
  gsap.utils.toArray<HTMLElement>('.card-object').forEach((obj) => {
    gsap.to(obj, {
      y: -20,
      ease: "none",
      scrollTrigger: {
        trigger: obj.closest('.bento-card'),
        start: "top bottom",
        end: "bottom top",
        scrub: 2,
      },
    });
  });
</script>
